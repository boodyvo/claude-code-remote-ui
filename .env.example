# ── Required ──

# Signs login session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=

# ── Optional ──

# Deepgram API key for voice dictation (get one at https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Comma-separated allowed origins for WebSocket connections (e.g. https://claude.example.com)
# Leave empty to allow all origins (fine for single-user self-hosted)
ALLOWED_ORIGINS=

# Working directory for Claude sessions inside the container
CLAUDE_CWD=/app/workspace

# SQLite database path
DATABASE_PATH=/app/data/connector.db
